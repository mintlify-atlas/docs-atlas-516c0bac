  "keyFeatures": [
    "Centralized app version tracking dashboard",
    "Real-time data updates from multiple app stores",
    "Web scrapers for Google Play, App Store, Microsoft Store, and Huawei AppGallery",
    "Theme switching (light/dark mode)",
    "Admin mode for bypassing rate limits",
    "Internationalization (i18n) support",
    "Responsive design with modern UI components",
    "Automated data validation with Zod schemas"
  ],
  "publicApiSurface": [
    "GET /api/data - Retrieve app version data",
    "POST /api/update - Trigger data update",
    "ScraperService.scrapeAll() - Scrape all configured apps",
    "GooglePlayScraper.scrape() - Scrape Google Play Store",
    "AppStoreScraper.scrape() - Scrape Apple App Store",
    "MicrosoftStoreScraper.scrape() - Scrape Microsoft Store",
    "HuaweiScraper.scrape() - Scrape Huawei AppGallery",
    "ScraperFactory.getScraper() - Get scraper by type"
  ]
